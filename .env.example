# Shared
NODE_ENV=development

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ipl_polling?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# Web
NEXT_PUBLIC_APP_NAME="IPL Polling Club"
NEXT_PUBLIC_ADMIN_EMAILS="admin@example.com"
API_SERVICE_URL="http://localhost:4000"

# API
PORT=4000
JWT_SECRET="replace-me"

# Schedule / Match ingestion
CRICKET_DATA_PROVIDER="manual"
CRICKET_API_KEY=""

# Optional WhatsApp notification bridge
WHATSAPP_WEBHOOK_SECRET=""
